{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowJs": true,
    "types": ["jest", "node"],
    "strict": true,
    "noEmit": false,
    "rootDir": ".",
    "outDir": "./dist",
    "isolatedModules": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "../src/**/*.ts",
    "../src/**/*.vue"
  ]
}
