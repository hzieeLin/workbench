{
  "name": "personal-task-orchestrator",
  "private": true,
  "version": "0.1.0",
  "description": "A personal task orchestrator desktop application",
  "author": "TaskFlow Team",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.taskflow.app",
    "productName": "TaskFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npm:dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build:electron && npm run build && electron-builder",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:component": "jest tests/components",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "mysql2": "^3.22.5",
    "pinia": "^3.0.4",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^1.0.0",
    "vue": "^3.5.38",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@playwright/test": "^1.60.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "@vue/vue3-jest": "^29.2.6",
    "babel-jest": "^30.4.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.33.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.4",
    "wait-on": "^9.0.10"
  }
}
